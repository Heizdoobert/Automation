[MESSAGES CONTROL]
# Disabled rules:
# C0114 missing-module-docstring
# C0115 missing-class-docstring
# C0116 missing-function-docstring
# C0411 wrong-import-order        — pages import local helpers before stdlib, intentional
# W0401 wildcard-import           — airtest uses "from api import *"
# W0614 unused-wildcard-import    — same reason
# E0401 import-error              — airtest native libs not installed on CI
# E0602 undefined-variable        — logwrap, G, sleep, touch etc come from airtest import *
# E1101 no-member                 — cv2, airtest members not resolved without native libs
# R0903 too-few-public-methods    — test helper classes intentionally small
# W0611 unused-import             — some airtest names imported for re-export
disable=
    C0114, # missing-module-docstring 
    C0115, # missing-class-docstring
    C0116, # missing-function-docstring
    W0401, # wildcard-import (Bắt buộc do thiết kế của Airtest)
    W0614  # unused-wildcard-import

[TYPECHECK]
extension-pkg-allow-list=cv2,numpy

[VARIABLES]
ignored-modules=airtest,paddleocr,paddle
additional-builtins=G,ST,Template,touch,wait,sleep,snapshot,log,start_app,stop_app,keyevent,text

[FORMAT]
max-line-length=110

[DESIGN]
max-args=8
